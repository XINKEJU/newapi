# ============================================================================
# new-api 俄罗斯部署 — 环境变量参考
# 复制此文件为 .env 并根据实际情况修改
# ============================================================================

# ── 基础配置 ────────────────────────────────────────────────────────────────
SESSION_SECRET=<random_64_char_string>
SQL_DSN=postgresql://user:password@postgres:5432/newapi?sslmode=disable
REDIS_CONN_STRING=redis://:password@redis:6379
TZ=Europe/Moscow

# ── 货币与汇率（俄罗斯本地化） ─────────────────────────────────────────────
QUOTA_DISPLAY_TYPE=RUB          # 显示货币：RUB（默认 USD）
PRICE=90                         # 1 USD = X RUB 的充值价格
RUB_EXCHANGE_RATE=90             # 1 USD = X RUB
CNY_EXCHANGE_RATE=7.25           # 1 USD = X CNY

# ── YooMoney 支付 ───────────────────────────────────────────────────────────
YOOMONEY_ENABLED=true
YOOMONEY_WALLET_ID=<your_yoomoney_wallet_id>
YOOMONEY_NOTIFY_SECRET=<your_notification_secret>
YOOMONEY_CURRENCY=RUB
YOOMONEY_MIN_TOPUP=50
YOOMONEY_TEST_MODE=false        # 生产环境必须设为 false

# ── OAuth 社交登录 ──────────────────────────────────────────────────────────
# VK (VKontakte)
VK_OAUTH_ENABLED=true
VK_CLIENT_ID=<your_vk_app_id>
VK_CLIENT_SECRET=<your_vk_secure_key>

# Yandex ID
YANDEX_OAUTH_ENABLED=true
YANDEX_CLIENT_ID=<your_yandex_app_id>
YANDEX_CLIENT_SECRET=<your_yandex_app_secret>

# Telegram Login Widget
TELEGRAM_OAUTH_ENABLED=true
TELEGRAM_BOT_TOKEN=<your_bot_token>
TELEGRAM_BOT_NAME=<your_bot_username>

# GitHub（可选）
# GITHUB_OAUTH_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── SMS 验证（俄罗斯 SMS.ru） ────────────────────────────────────────────
SMS_ENABLED=false                # 设为 true 启用
SMS_PROVIDER=smsru
SMS_API_ID=<your_smsru_api_id>
SMS_SENDER=<your_sender_name>

# ── 部署域名 ────────────────────────────────────────────────────────────────
TRUSTED_REDIRECT_DOMAINS=yourdomain.ru
