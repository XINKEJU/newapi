# New-API 生产环境变量模板
# 复制此文件为 .env.prod 并填入真实值
# .env.prod 不会被提交到 Git（已在 .gitignore 中排除）

# ============ PostgreSQL ============
POSTGRES_USER=newapi
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=newapi

# ============ Redis ============
REDIS_PASSWORD=your_strong_redis_password_here

# ============ New-API 应用 ============
SQL_DSN=postgresql://newapi:your_strong_password_here@postgres:5432/newapi?sslmode=disable
REDIS_CONN_STRING=redis://:your_strong_redis_password_here@redis:6379
SESSION_SECRET=generate_a_random_64_char_hex_string_here
